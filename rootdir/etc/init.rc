# Creek Minimal Boot Init (Director Script)
# This file imports hardware-specific logic from separate RC files

import /vendor/etc/init/hw/init.qti.display_boot.rc
import /vendor/etc/init/init.vendor.sensors.rc
import /vendor/etc/init/init.creek.hw.rc
import /vendor/etc/init/init.target.rc

on early-init
    # Standard early startup
    start ueventd

on init
    # Core path exports
    export PATH /product/bin:/apex/com.android.runtime/bin:/system/bin:/system/xbin:/vendor/bin:/vendor/xbin

on post-fs-data
    # Start basic logging
    start logd

on boot
    # Basic boot animation trigger
    setprop debug.sf.nobootanimation 0
    start bootanim
