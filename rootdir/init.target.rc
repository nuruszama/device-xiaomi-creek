#
# Copyright (C) 2026 The LineageOS Project
#
# Hardware-specific initialization for Xiaomi POCO M7 4G (Creek)
#

on early-init
    # Set up memory and CPU tuning for faster boot
    exec u:r:vendor_modprobe:s0 -- /vendor/bin/modprobe -a -d /vendor/lib/modules qcom_hw_irq

on init
    # Generic Android environment setup
    write /sys/kernel/cnss/recovery 1

on fs
    # Register the Wi-Fi tracing instance
    setprop sys.wifitracing.started -1

on post-fs
    # Start the Time Daemon to sync hardware and system clocks
    start time_daemon

on post-fs-data
    # Create directory for Wi-Fi APEX data (Required for Android 15+)
    mkdir /data/misc/apexdata/com.android.wifi 0770 wifi wifi
    restorecon_recursive /data/misc/apexdata/com.android.wifi

    # Create directory for proprietary Xiaomi/MIUI components
    mkdir /data/vendor/mi_ic 2771 root log

on boot
    # Set up permissions for double tap to wake (DT2W)
    # Note: Path may vary based on your specific touch panel driver
    chown system system /sys/devices/virtual/input/lxs_ts_input/enable_knock
    chmod 0660 /sys/devices/virtual/input/lxs_ts_input/enable_knock

    # Set up permissions for charging and PD authentication[cite: 1]
    chown system system /sys/class/power_supply/usb/pd_authentication
    chmod 0664 /sys/class/power_supply/usb/pd_authentication

on property:vendor.post_boot.parsed=1
    # IRQ Tuning: Pinning critical interrupts to specific CPU cores[cite: 1]
    # Check /proc/interrupts on a running device to verify these IDs
    write /proc/irq/246/smp_affinity_list 2  # msm_drm (Display)
    write /proc/irq/43/smp_affinity_list 1   # kgsl_3d0 (GPU)

on property:sys.boot_completed=1
    # Enable ZRAM and start battery secret service[cite: 1]
    swapon_all /vendor/etc/fstab.zram
    start batterysecret

# Services[cite: 1]

service time_daemon /vendor/bin/time_daemon
    class main
    user system
    group system
    capabilities SYS_TIME

service batterysecret /vendor/bin/batterysecret
    class last_start
    user root
    group system system wakelock
    disabled
    seclabel u:r:batterysecret:s0

service vendor.nfc_hal_service /vendor/bin/hw/android.hardware.nfc-service.nxp
    class early_hal
    user nfc
    group nfc drmrpc system
    disabled

# Start NFC based on your device SKU[cite: 1]
on post-fs && property:ro.boot.product.hardware.sku=o19ae
    start vendor.nfc_hal_service